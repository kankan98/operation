{
  "name": "badminton-liveops-ai",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "dev": "pnpm --filter @operation/web dev",
    "build": "pnpm --filter @operation/web build",
    "lint": "pnpm --filter @operation/web lint",
    "typecheck": "pnpm --filter @operation/web typecheck",
    "check": "pnpm lint && pnpm typecheck && pnpm build",
    "db:generate": "pnpm --filter @operation/web db:generate",
    "db:migrate": "pnpm --filter @operation/web db:migrate",
    "db:check": "pnpm --filter @operation/web db:check",
    "auth:check": "pnpm --filter @operation/web auth:check",
    "auth:session-check": "pnpm --filter @operation/web auth:session-check",
    "auth:cookie-check": "pnpm --filter @operation/web auth:cookie-check",
    "auth:route-check": "pnpm --filter @operation/web auth:route-check",
    "operator-v0:check": "pnpm --filter @operation/web operator-v0:check",
    "internal-trial:check": "pnpm --filter @operation/web internal-trial:check",
    "trial-mvp:check": "pnpm --filter @operation/web trial-mvp:check",
    "trial-demo:check": "pnpm --filter @operation/web trial-demo:check",
    "trial-feedback:check": "pnpm --filter @operation/web trial-feedback:check",
    "public-trial-auth:check": "pnpm --filter @operation/web public-trial-auth:check",
    "reference-data:v0-check": "pnpm --filter @operation/web reference-data:v0-check",
    "downstream:v0-check": "pnpm --filter @operation/web downstream:v0-check",
    "knowledge:check": "pnpm --filter @operation/web knowledge:check",
    "knowledge:route-check": "pnpm --filter @operation/web knowledge:route-check",
    "next-actions:check": "pnpm --filter @operation/web next-actions:check",
    "next-actions:route-check": "pnpm --filter @operation/web next-actions:route-check",
    "talk-tracks:check": "pnpm --filter @operation/web talk-tracks:check",
    "talk-tracks:route-check": "pnpm --filter @operation/web talk-tracks:route-check",
    "ai-review:check": "pnpm --filter @operation/web ai-review:check",
    "ai-review:execution-check": "pnpm --filter @operation/web ai-review:execution-check",
    "ai-review:generation-check": "pnpm --filter @operation/web ai-review:generation-check",
    "ai-review:route-check": "pnpm --filter @operation/web ai-review:route-check",
    "ai-review:live-gate-check": "pnpm --filter @operation/web ai-review:live-gate-check",
    "ai-review:v0-check": "pnpm --filter @operation/web ai-review:v0-check",
    "ai-provider:check": "pnpm --filter @operation/web ai-provider:check",
    "sessions:check": "pnpm --filter @operation/web sessions:check",
    "sessions:route-check": "pnpm --filter @operation/web sessions:route-check",
    "rackets:check": "pnpm --filter @operation/web rackets:check",
    "rackets:source-review-check": "pnpm --filter @operation/web rackets:source-review-check",
    "rackets:route-check": "pnpm --filter @operation/web rackets:route-check",
    "docker:build": "docker build -t operation-web .",
    "docker:run": "docker run --rm -p 3000:3000 operation-web",
    "docker:preview": "docker run -d --name operation-web-preview --restart unless-stopped --network operation_default -p 3000:3000 -e DATABASE_URL=${OPERATION_PREVIEW_DATABASE_URL:-postgres://operation:operation_dev_password@postgres:5432/operation_dev} -e OPERATION_ENABLE_V0_BOOTSTRAP=1 -e OPERATION_ALLOW_INSECURE_V0_PREVIEW_COOKIE=1 operation-web"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
