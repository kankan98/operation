# ====================================
# 服务配置
# ====================================
# 运行环境：development | production
NODE_ENV=development

# 服务器端口
PORT=3001

# ====================================
# 数据库
# ====================================
# SQLite 数据库文件路径（相对或绝对路径）
DATABASE_PATH=./data/ecommerce.db

# ====================================
# 日志
# ====================================
# 日志级别：debug | info | warn | error
# - debug: 详细调试信息
# - info: 常规信息（推荐开发环境）
# - warn: 警告信息
# - error: 仅错误信息（推荐生产环境）
LOG_LEVEL=info

# ====================================
# CORS
# ====================================
# CORS 允许的源（前端地址）
# 开发环境通常是 http://localhost:3000
# 生产环境设置为实际前端域名
CORS_ORIGIN=http://localhost:3000

# ====================================
# AI Provider Configuration
# ====================================
# 支持多种 AI 提供商和协议

# AI 提供商类型
# - anthropic: 使用 Anthropic SDK (Claude 官方协议)
# - openai: 使用 OpenAI SDK (兼容 OpenAI/DeepSeek/其他)
AI_PROVIDER=anthropic

# === Anthropic 协议配置 ===
# API Key
# - Claude: 从 https://console.anthropic.com/settings/keys 获取
# - DeepSeek (Anthropic): 从 https://platform.deepseek.com/api_keys 获取
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Base URL（可选）
# - Claude（默认）: 留空或 https://api.anthropic.com
# - DeepSeek (Anthropic): https://api.deepseek.com/anthropic
ANTHROPIC_BASE_URL=

# 模型名称
# - Claude: claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5
# - DeepSeek (Anthropic): deepseek-chat | deepseek-reasoner
ANTHROPIC_MODEL=claude-opus-4-8

# === OpenAI 协议配置 ===
# API Key
# - OpenAI: 从 https://platform.openai.com/api-keys 获取
# - DeepSeek (OpenAI): 从 https://platform.deepseek.com/api_keys 获取
OPENAI_API_KEY=sk-your-openai-api-key-here

# Base URL（可选）
# - OpenAI（默认）: 留空或 https://api.openai.com/v1
# - DeepSeek (OpenAI): https://api.deepseek.com
OPENAI_BASE_URL=

# 模型名称
# - OpenAI: gpt-4 | gpt-4-turbo | gpt-3.5-turbo
# - DeepSeek (OpenAI): deepseek-chat | deepseek-coder
OPENAI_MODEL=gpt-4

