# ====================================
# 服务配置
# ====================================
# 运行环境：development | production
NODE_ENV=development

# 服务器端口
PORT=3001

# ====================================
# 数据库
# ====================================
# SQLite 数据库文件路径（相对或绝对路径）
DATABASE_PATH=./data/ecommerce.db

# ====================================
# 日志
# ====================================
# 日志级别：debug | info | warn | error
# - debug: 详细调试信息
# - info: 常规信息（推荐开发环境）
# - warn: 警告信息
# - error: 仅错误信息（推荐生产环境）
LOG_LEVEL=info

# ====================================
# CORS
# ====================================
# CORS 允许的源（前端地址）
# 开发环境通常是 http://localhost:3000
# 生产环境设置为实际前端域名
CORS_ORIGIN=http://localhost:3000

# ====================================
# AI Provider Configuration
# ====================================
# 支持多种 AI 提供商和协议

# AI 提供商类型
# - anthropic: 使用 Anthropic SDK (Claude 官方协议)
# - openai: 使用 OpenAI SDK (兼容 OpenAI/DeepSeek/其他)
AI_PROVIDER=anthropic

# === Anthropic 协议配置 ===
# API Key
# - Claude: 从 https://console.anthropic.com/settings/keys 获取
# - DeepSeek (Anthropic): 从 https://platform.deepseek.com/api_keys 获取
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Base URL（可选）
# - Claude（默认）: 留空或 https://api.anthropic.com
# - DeepSeek (Anthropic): https://api.deepseek.com/anthropic
ANTHROPIC_BASE_URL=

# 模型名称
# - Claude: claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5
# - DeepSeek (Anthropic): deepseek-chat | deepseek-reasoner
ANTHROPIC_MODEL=claude-opus-4-8

# === OpenAI 协议配置 ===
# API Key
# - OpenAI: 从 https://platform.openai.com/api-keys 获取
# - DeepSeek (OpenAI): 从 https://platform.deepseek.com/api_keys 获取
OPENAI_API_KEY=sk-your-openai-api-key-here

# Base URL（可选）
# - OpenAI（默认）: 留空或 https://api.openai.com/v1
# - DeepSeek (OpenAI): https://api.deepseek.com
OPENAI_BASE_URL=

# 模型名称
# - OpenAI: gpt-4 | gpt-4-turbo | gpt-3.5-turbo
# - DeepSeek (OpenAI): deepseek-chat | deepseek-coder
OPENAI_MODEL=gpt-4

# ====================================
# Product Data Acquisition
# ====================================
# Provider order for product acquisition.
# Recommended first path: approved API/third-party provider first, browser fallback last.
# Current built-in providers: rainforest, amazon-browser, ebay-browse
ACQUISITION_PROVIDER_ORDER=rainforest,amazon-browser,ebay-browse

# Enable Playwright browser fallback when API/third-party providers are unavailable.
ACQUISITION_BROWSER_FALLBACK_ENABLED=true

# Job retry and lease settings.
ACQUISITION_MAX_ATTEMPTS=3
ACQUISITION_BASE_BACKOFF_MS=300000
ACQUISITION_MAX_BACKOFF_MS=3600000
ACQUISITION_JOB_LEASE_MS=300000

# Cached product data can be accepted as fallback within this freshness window.
ACQUISITION_CACHE_FRESHNESS_MS=21600000

# Capture non-sensitive page diagnostics such as title, final URL, and detected state.
ACQUISITION_CAPTURE_DIAGNOSTICS=true

# Maximum number of due jobs processed per scheduler tick.
ACQUISITION_PROCESS_LIMIT=10

# === Acquisition queue operations ===
# Default local backend keeps durable SQLite scrape_jobs/scrape_attempts as the source of truth.
# Set to bullmq only when Redis is configured and workers are deployed.
ACQUISITION_QUEUE_BACKEND=sqlite
REDIS_URL=
ACQUISITION_WORKER_CONCURRENCY=4
ACQUISITION_WORKER_HEARTBEAT_INTERVAL_MS=30000
ACQUISITION_STALE_WORKER_THRESHOLD_MS=120000
ACQUISITION_MANUAL_REFRESH_THROTTLE_MS=300000
ACQUISITION_PROVIDER_DEFAULT_CONCURRENCY=2
ACQUISITION_BROWSER_FALLBACK_CONCURRENCY=1
ACQUISITION_PROVIDER_RATE_LIMIT_RESET_MS=900000
ACQUISITION_DEGRADED_BACKLOG_THRESHOLD=50

# === Rainforest Amazon provider ===
# Missing key is treated as provider_unavailable and falls back to the next provider.
RAINFOREST_API_KEY=
RAINFOREST_MARKETPLACE=amazon.com
RAINFOREST_TIMEOUT_MS=30000
RAINFOREST_CAPTURE_DIAGNOSTICS=true

# === eBay Browse API provider ===
# Uses official eBay OAuth client-credentials flow and Browse API item lookup.
# Missing credentials are reported as provider_unavailable with safe diagnostics.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE=EBAY_US
EBAY_API_BASE_URL=https://api.ebay.com
EBAY_OAUTH_BASE_URL=https://api.ebay.com
EBAY_TIMEOUT_MS=30000
EBAY_CAPTURE_DIAGNOSTICS=true

# ====================================
# Market Signal Acquisition
# ====================================
# Market signals are historical/proxy trend data, separate from live listing checks.
# Current built-in provider: keepa
MARKET_SIGNAL_PROVIDER_ORDER=keepa
MARKET_SIGNAL_REFRESH_WINDOW_DAYS=90
MARKET_SIGNAL_FRESHNESS_MS=604800000
MARKET_SIGNAL_CAPTURE_DIAGNOSTICS=true

# === Keepa market signal provider ===
# Missing key is treated as provider_unavailable and does not affect listing acquisition.
# Keepa domain 1 maps to amazon.com.
KEEPA_ENABLED=true
KEEPA_API_KEY=
KEEPA_API_BASE_URL=https://api.keepa.com
KEEPA_DOMAIN=1
KEEPA_MARKETPLACE=amazon.com
KEEPA_TIMEOUT_MS=30000
KEEPA_CAPTURE_DIAGNOSTICS=true
